       IDENTIFICATION DIVISION.
       PROGRAM-ID. INTEREST-CALC.
       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT INTEREST-FILE
               ASSIGN TO ACCT.INTEREST.VSAM
               ORGANIZATION IS INDEXED.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       COPY INTEREST-COPY.
       01 WS-RATE            PIC 9(3)V9(4).
       PROCEDURE DIVISION.
       MAIN-LOGIC.
           MOVE 0.0525 TO WS-RATE
           COMPUTE WS-INTEREST = WS-PRINCIPAL * WS-RATE * WS-TERM
           CALL 'AUDIT-TRAIL' USING WS-INTEREST
           STOP RUN.

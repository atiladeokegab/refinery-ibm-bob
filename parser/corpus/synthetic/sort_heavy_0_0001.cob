       IDENTIFICATION DIVISION.
       PROGRAM-ID. SRTH0001.
       AUTHOR. ZOPTIMA-GEN.
       ENVIRONMENT DIVISION.
       INPUT-OUTPUT SECTION.
       FILE-CONTROL.
           SELECT INFILE  ASSIGN TO 'INPUT.DAT'
               ORGANIZATION IS SEQUENTIAL.
           SELECT OUTFILE ASSIGN TO 'OUTPUT.DAT'
               ORGANIZATION IS SEQUENTIAL.
       DATA DIVISION.
       FILE SECTION.
       FD  INFILE.
       01  IN-RECORD        PIC X(80).
       FD  OUTFILE.
       01  OUT-RECORD       PIC X(80).

       WORKING-STORAGE SECTION.
       01  WS-VAR-000        PIC X(20) VALUE ZERO.
       01  WS-VAR-001        PIC 9(3) VALUE ZERO.
       01  WS-VAR-002        PIC X(20) VALUE ZERO.
       01  WS-VAR-003        PIC 9(7)V99 VALUE ZERO.
       01  WS-VAR-004        PIC 9(3) VALUE ZERO.
       01  WS-VAR-005        PIC 9(3) VALUE ZERO.
       01  WS-VAR-006        PIC X(20) VALUE ZERO.
       01  WS-VAR-007        PIC 9(5) VALUE ZERO.
       01  WS-VAR-008        PIC 9(5) VALUE ZERO.

       PROCEDURE DIVISION.
       MAIN-LOGIC.
       SORT INFILE
           ON ASCENDING KEY IN-RECORD
           INPUT PROCEDURE IS SORT-INPUT-0
           OUTPUT PROCEDURE IS SORT-OUTPUT-0.
       SORT INFILE
           ON ASCENDING KEY IN-RECORD
           INPUT PROCEDURE IS SORT-INPUT-1
           OUTPUT PROCEDURE IS SORT-OUTPUT-1.
       SORT INFILE
           ON ASCENDING KEY IN-RECORD
           INPUT PROCEDURE IS SORT-INPUT-2
           OUTPUT PROCEDURE IS SORT-OUTPUT-2.           STOP RUN.
